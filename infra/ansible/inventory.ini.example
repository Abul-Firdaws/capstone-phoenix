; Copy to inventory.ini (gitignored) and fill in the real IPs from `terraform output`.
[control_plane]
cp1 ansible_host=<CONTROL_PLANE_PUBLIC_IP> private_ip=<CONTROL_PLANE_PRIVATE_IP>

[workers]
worker1 ansible_host=<WORKER1_PUBLIC_IP>
worker2 ansible_host=<WORKER2_PUBLIC_IP>

[all:vars]
ansible_user=ubuntu
ansible_ssh_private_key_file=~/.ssh/phoenix_key.pem
ansible_ssh_common_args='-o StrictHostKeyChecking=no'

# Copy this to terraform.tfvars (gitignored) and fill in your real values.
aws_region    = "us-east-1"
my_ip         = "203.0.113.5/32"   # replace with YOUR public IP + /32 — get it with: curl -s ifconfig.me
key_name      = "phoenix-key"      # the EC2 key pair name you create in Phase 1
instance_type = "t3.medium"
worker_count  = 2
